# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Site Configuration
SITE_URL=https://poodasamuel.com
NEXT_PUBLIC_SITE_NAME=Samuel POODA Portfolio

# Email Configuration (Resend - Recommended for Vercel)
RESEND_API_KEY=your_resend_api_key_here

# Or use SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# Or use custom SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# API Keys for Automation (Optional)
OPENAI_API_KEY=your_openai_api_key_for_article_generation

# Social Media API Keys (Optional - for auto-publishing)
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret

# Database (Optional - for future CRM features)
DATABASE_URL=your_database_url_here
